# =============================================================
# 🚀 GOGISISE NestJS Backend - 환경변수 템플릿 (.env.example)
# =============================================================
# ⚠️  이 파일은 팀 공유용 템플릿입니다. 실제 값을 채워 .env 파일을 만드세요.
# ⚠️  실제 값이 담긴 .env, .env.deploy 파일은 절대 깃허브에 올리지 마세요!
# =============================================================

PORT=8000
NODE_ENV="development"

# -----------------------------------------------
# 🗄️  데이터베이스 (Supabase PostgreSQL)
# -----------------------------------------------
# 로컬 Docker: postgresql://gogisise_user:gogisise_secure_password@postgres:5432/gogisise_db?schema=public
# 프로덕션:    Supabase Connection Pooler URL (포트 6543, pgbouncer=true)
DATABASE_URL=""

# -----------------------------------------------
# 🔐  보안 키 (절대 기본값 사용 금지)
# -----------------------------------------------
# 내부 크롤러 API 인증 키 (크롤러 서버와 동일한 값으로 설정)
INTERNAL_API_KEY=""

# JWT 서명 키 (최소 32자 이상의 무작위 문자열 권장)
JWT_SECRET=""
JWT_ACCESS_EXPIRES_IN="1h"
JWT_REFRESH_EXPIRES_IN="30d"

# -----------------------------------------------
# 📦  Redis (세션 캐시 및 조회수 버퍼링)
# -----------------------------------------------
# 로컬 Docker: redis (컨테이너명)
# 프로덕션:    Upstash 등 외부 Redis 서비스 URL
REDIS_HOST=""
REDIS_PORT=6379

# -----------------------------------------------
# 🟡  카카오 소셜 로그인
# -----------------------------------------------
KAKAO_REST_API_KEY=""
KAKAO_USER_INFO_URL="https://kapi.kakao.com/v2/user/me"
