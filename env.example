POSTGRES_USER=gogisise_user
POSTGRES_PASSWORD=gogisise_secure_password
POSTGRES_DB=gogisise_db
PORT=8000
DATABASE_URL="postgresql://gogisise_user:gogisise_secure_password@postgres:5432/gogisise_db?schema=public"
INTERNAL_API_KEY="gogisise_super_secret_internal_key_2026"

# --- 환경 식별 (개발: development, 운영: production) ---
NODE_ENV="development"

# --- JWT 암호화 키 (운영 환경에서는 반드시 안전한 랜덤 문자열로 교체해야 함!) ---
JWT_SECRET="gogisise_jwt_super_secret_key_change_this_in_production_2026"
JWT_ACCESS_EXPIRES_IN="1h"
JWT_REFRESH_EXPIRES_IN="30d"

# --- Redis 연결 설정 ---
REDIS_HOST="redis"
REDIS_PORT="6379"

# --- 카카오 소셜 로그인 설정 (https://developers.kakao.com 에서 앱 키 발급) ---
KAKAO_REST_API_KEY="your_kakao_rest_api_key_here"
KAKAO_USER_INFO_URL="https://kapi.kakao.com/v2/user/me"
